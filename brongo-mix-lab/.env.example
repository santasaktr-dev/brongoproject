# เปิด/ปิด analytics (ค่าเริ่มต้นปิด). ตั้ง "true" เพื่อเปิด
NEXT_PUBLIC_ANALYTICS_ENABLED=false

# URL เว็บ (ใช้ประกอบลิงก์แชร์) — ตั้งให้ตรงโดเมน production
NEXT_PUBLIC_SITE_URL=https://brongoproject.vercel.app

# ลิงก์ LINE Official Account ของ BRONGO (ปุ่ม "ถามเภสัชกร") — ใส่ค่าจริงเมื่อได้ OA
NEXT_PUBLIC_LINE_OA_URL=https://line.me/
